# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL=

# ── Auth.js ───────────────────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Razorpay (test mode) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Cloudinary ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI (Google Gemini) ────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# ── Admin seed (used by prisma/seed.ts) ───────────────────────────────────
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
